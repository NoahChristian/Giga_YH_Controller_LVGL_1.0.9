# Arduino IDE temporary build folders
/build/
/bin/

#Arduino personal identification file
arduino_secrets.h

# Hardware specific compiled files
*.elf
*.hex
*.d
*.o

# Visual Studio Code / PlatformIO temporary files
.pio/
.pioenvs/
.piolibdeps/
.vscode/

# Python bytecode cache (tools/ screen exporter scripts)
__pycache__/
*.pyc

# Screen exporter output -- regenerable via tools/capture_all.py, not
# tracked; the captures/ directory and the exporter scripts themselves
# still are.
Giga_YH_Dashboard_Unit2/tools/captures/*.png
Giga_YH_Dashboard_Unit2/tools/captures/*.csv

# System specific junk files
.DS_Store
Thumbs.db